generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum Frequency {
  ONCE
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum AccountType {
  BANK
  PRECIOUS_METALS
  CRYPTO
}

enum BankProvider {
  PLAID
}

enum BankConnectionStatus {
  ACTIVE
  NEEDS_REAUTH
  DISCONNECTED
}

model User {
  id                       String                    @id @default(cuid())
  email                    String                    @unique
  passwordHash             String
  name                     String?
  appleUserId              String?                   @unique
  pushToken                String?
  currentBalance           Decimal                   @default(0) @db.Decimal(12, 2)
  goalAmount               Decimal?                  @db.Decimal(12, 2)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  transactions             Transaction[]
  categories               Category[]
  budgetGoals              BudgetGoal[]
  accounts                 Account[]
  bankConnections          BankConnection[]
  bankImportedTransactions BankImportedTransaction[]
  bankRecurringRules       BankRecurringRule[]
}

model Category {
  id           String           @id @default(cuid())
  userId       String
  name         String
  type         TransactionType?
  color        String?
  icon         String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([userId, name])
}

model Transaction {
  id                     String          @id @default(cuid())
  userId                 String
  accountId              String?
  title                  String
  amount                 Decimal         @db.Decimal(12, 2)
  type                   TransactionType
  frequency              Frequency       @default(ONCE)
  recurrenceIntervalDays Int?
  date                   DateTime
  endDate                DateTime?
  categoryId             String?
  note                   String?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  user                   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  account                Account?        @relation(fields: [accountId], references: [id], onDelete: SetNull)
  category               Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([userId, accountId, date])
}

model Account {
  id             String        @id @default(cuid())
  userId         String
  name           String
  type           AccountType   @default(BANK)
  icon           String?
  color          String?
  currentBalance Decimal       @default(0) @db.Decimal(12, 2)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions   Transaction[]

  @@unique([userId, name])
  @@index([userId, type])
}

model BudgetGoal {
  id           String   @id @default(cuid())
  userId       String
  year         Int
  targetAmount Decimal  @db.Decimal(12, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year])
}

model BankConnection {
  id                   String                    @id @default(cuid())
  userId               String
  provider             BankProvider              @default(PLAID)
  status               BankConnectionStatus      @default(ACTIVE)
  providerItemId       String
  providerAccessToken  String
  institutionId        String?
  institutionName      String?
  cursor               String?
  lastSyncedAt         DateTime?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  user                 User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  importedTransactions BankImportedTransaction[]
  recurringRules       BankRecurringRule[]

  @@unique([provider, providerItemId])
  @@index([userId, status])
}

model BankImportedTransaction {
  id                    String          @id @default(cuid())
  userId                String
  bankConnectionId      String
  providerTransactionId String
  name                  String
  normalizedName        String
  merchantName          String?
  amount                Decimal         @db.Decimal(12, 2)
  type                  TransactionType
  date                  DateTime
  pending               Boolean         @default(false)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection            BankConnection  @relation(fields: [bankConnectionId], references: [id], onDelete: Cascade)

  @@unique([bankConnectionId, providerTransactionId])
  @@index([userId, date])
  @@index([bankConnectionId, normalizedName])
}

model BankRecurringRule {
  id                     String          @id @default(cuid())
  userId                 String
  bankConnectionId       String
  signature              String
  title                  String
  amount                 Decimal         @db.Decimal(12, 2)
  type                   TransactionType
  frequency              Frequency
  recurrenceIntervalDays Int?
  nextDate               DateTime
  localTransactionId     String?
  lastDetectedAt         DateTime
  active                 Boolean         @default(true)
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  user                   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection             BankConnection  @relation(fields: [bankConnectionId], references: [id], onDelete: Cascade)

  @@unique([bankConnectionId, signature])
  @@index([userId, active])
}
